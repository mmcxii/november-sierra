{
  "*.json": ["sortier --write", "prettier --write"],
  "*.md": ["prettier --write"],
  "*.{ts,tsx,js,cjs,mjs}": ["eslint --fix", "sortier --write", "prettier --write"],
  "drizzle/*.sql": ["node --no-warnings scripts/validate-schema-migrations.ts"],
  "src/lib/db/schema/**/*.ts": ["node --no-warnings scripts/validate-schema-migrations.ts"],
  "src/lib/i18n/locales/*.json": ["node --no-warnings scripts/validate-i18n-keys.ts"]
}
