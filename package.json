{
  "devDependencies": {
    "commitlint": "20.5.0",
    "eslint": "^10.2.0",
    "husky": "9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "16.4.0",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "sortier": "2.1.1",
    "turbo": "^2.9.5",
    "typescript": "6.0.2",
    "vitest": "^4.1.3"
  },
  "license": "SEE LICENSE IN LICENSE",
  "name": "november-sierra",
  "packageManager": "pnpm@10.33.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "husky:commit-msg": "commitlint --edit $1",
    "husky:post-merge": "pnpm install --ignore-scripts",
    "husky:pre-commit": "lint-staged && turbo run typecheck",
    "lint": "turbo run lint",
    "prepare": "husky",
    "test": "turbo run test && vitest run --config vitest.config.ts",
    "typecheck": "turbo run typecheck"
  },
  "version": "0.0.0"
}
