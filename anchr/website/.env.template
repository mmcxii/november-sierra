# App
NEXT_PUBLIC_APP_URL="string"
NEXT_PUBLIC_SHORT_DOMAIN="anch.to"
ADMIN_USER_ID="string"

# Database (Neon)
DATABASE_URL="string"

# Auth (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="string"
CLERK_SECRET_KEY="string"
CLERK_WEBHOOK_SECRET="string"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="string"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="string"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="string"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="string"

# File Storage (Uploadthing)
UPLOADTHING_TOKEN="string"

# Email (Resend)
RESEND_API_KEY="string"

# Payments (Stripe)
# IMPORTANT: STRIPE_PRO_PRICE_ID_MONTHLY and STRIPE_PRO_PRICE_ID_ANNUAL must
# both be price ids (price_…), NOT product ids (prod_…). Setting either to
# the product id silently fails checkout creation at runtime. Boot-time
# validation in src/lib/env.ts catches the misconfig.
STRIPE_SECRET_KEY="sk_test_…"               # sk_test_… or sk_live_… (or rk_… restricted)
STRIPE_WEBHOOK_SECRET="whsec_…"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_…"
STRIPE_PRO_PRICE_ID_MONTHLY="price_…"        # Stripe price id for the monthly Pro plan
STRIPE_PRO_PRICE_ID_ANNUAL="price_…"         # Stripe price id for the annual Pro plan

# Cron Jobs (generate with: openssl rand -base64 32)
CRON_SECRET="string"

# Webhooks (generate with: openssl rand -hex 32)
WEBHOOK_SIGNING_ENCRYPTION_KEY="string"

# Rate Limiting (Upstash)
UPSTASH_REDIS_REST_URL="string"
UPSTASH_REDIS_REST_TOKEN="string"

# Vercel Domains API (https://vercel.com/account/tokens)
VERCEL_API_TOKEN="string"
VERCEL_PROJECT_ID="string"
# VERCEL_TEAM_ID="string" # optional — only needed for team accounts

# Analytics (PostHog)
NEXT_PUBLIC_POSTHOG_KEY="string"
NEXT_PUBLIC_POSTHOG_HOST="string"

# E2E Testing (shared password for seeded test users)
E2E_USER_PASSWORD="string"
